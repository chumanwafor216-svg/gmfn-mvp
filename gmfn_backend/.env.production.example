# Core runtime
GMFN_DEV_MODE=0
GMFN_AUTO_CREATE_SCHEMA=0
GMFN_ENABLE_RECONCILIATION_LOOP=1
GMFN_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Required
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
GMFN_SECRET_KEY=replace-with-a-long-random-secret
GMFN_HMAC_SECRET=replace-with-a-long-random-hmac-secret
GMFN_CORS_ORIGINS=https://app.example.com

# Strongly recommended
GMFN_WEBHOOK_SECRET=replace-if-you-enable-bank-webhooks
GMFN_UPLOADS_DIR=/var/data/gmfn-uploads

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
