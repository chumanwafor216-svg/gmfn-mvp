# scripts/bootstrap_dev.ps1
# Run from gmfn_backend folder.

$ErrorActionPreference = "Stop"

Write-Host "== GMFN Backend bootstrap ==" -ForegroundColor Cyan

# Go to backend root (this file is inside scripts/)
Set-Location (Split-Path $PSScriptRoot -Parent)

# Activate venv
if (!(Test-Path ".\.venv\Scripts\Activate.ps1")) {
  throw "Virtualenv not found at .venv. Create it first."
}
. .\.venv\Scripts\Activate.ps1

# Ensure env vars for auth (avoids random auth crashes)
$env:SECRET_KEY = "dev-secret-change-me"
$env:ALGORITHM = "HS256"

# Start server
Write-Host "Starting Uvicorn..." -ForegroundColor Green
python -m uvicorn app.main:app --reload --host 127.0.0.1 --port 8000 
